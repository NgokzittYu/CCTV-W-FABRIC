# Core Fabric and chaincode settings
FABRIC_SAMPLES_PATH=~/projects/fabric-samples
CHANNEL_NAME=mychannel
CHAINCODE_NAME=evidence
CAMERA_ID=bot128
CORE_PEER_TLS_ENABLED=true
CORE_PEER_LOCALMSPID=Org1MSP
CORE_PEER_ADDRESS=localhost:7051
ORDERER_ADDRESS=localhost:7050
ORDERER_TLS_HOSTNAME_OVERRIDE=orderer.example.com
ORG1_PEER_ADDRESS=localhost:7051
ORG2_PEER_ADDRESS=localhost:9051
ORG3_PEER_ADDRESS=localhost:11051
ORG1_DOMAIN=org1.example.com
ORG2_DOMAIN=org2.example.com
ORG3_DOMAIN=org3.example.com
ORDERER_ORG_DOMAIN=example.com
ORDERER_DOMAIN=orderer.example.com

# Evidence and stream settings
EVIDENCE_DIR=evidences
VIDEO_SOURCE=https://jtmctrafficcctv2.gov.taipei/NVR/0b0ea88c-4ac6-4e76-b1d0-6868c0354cf3/live.m3u8
CAMERA_CONFIGS=[{"device_id":"bot128","label":"基隆路","video_source":"https://jtmctrafficcctv2.gov.taipei/NVR/0b0ea88c-4ac6-4e76-b1d0-6868c0354cf3/live.m3u8"},{"device_id":"bot382","label":"忠孝东路 / 光复南路","video_source":"https://jtmctrafficcctv2.gov.taipei/NVR/4ad0b078-a5d3-4fa5-ae4d-c1b7a7ce7d7a/live.m3u8"},{"device_id":"bot287","label":"基隆路二段 / 嘉兴街","video_source":"https://jtmctrafficcctv5.gov.taipei/NVR/f6b2f98e-9456-4d89-9b30-b8ae98fe4062/live.m3u8"},{"device_id":"bot343","label":"市高光复西行","video_source":"https://jtmctrafficcctv3.gov.taipei/NVR/74f29e27-6d4c-4dd0-996b-9fe4a7b7bc4e/live.m3u8"},{"device_id":"bot136","label":"信义路","video_source":"https://jtmctrafficcctv2.gov.taipei/NVR/77671f83-baa4-48e9-b028-3d5f9f37f5e9/live.m3u8"}]

# Detection model and classes
MODEL_CANDIDATES=yolo11n.pt,yolo11m.pt,yolo11x.pt
DETECT_MODEL=yolo11n.pt
ROAD_TARGET_CLASS_IDS=0,1,2,3,5,7

# Web detection thresholds
CONFIDENCE_THRESHOLD=0.45

# Event aggregation settings
AGGREGATE_MIN_FRAMES=3
AGGREGATE_MAX_MISSED_FRAMES=6
AGGREGATE_IOU_THRESHOLD=0.45
AGGREGATE_WINDOW_SECONDS=5.0

# Merkle batch settings
MERKLE_BATCH_WINDOW_SECONDS=10
MERKLE_FLUSH_POLL_SECONDS=1.0

# detect.py defaults
DETECT_CONFIDENCE_THRESHOLD=0.25
DETECT_SAVE_EVERY=10
DETECT_OUTPUT_DIR=evidences
DETECT_IMGSZ=1280
DETECT_RECONNECT_EVERY=20
DETECT_RETRY_SLEEP=0.2
DETECT_RECONNECT_SLEEP=1.0

# Stage3 device signing
DEVICE_CERT_PATH=device_keys/default/cert.pem
DEVICE_KEY_PATH=device_keys/default/key.pem
DEVICE_SIGN_ALGO=ECDSA_SHA256
DEVICE_SIGNATURE_REQUIRED=true

# IPFS 去中心化存储
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080
IPFS_PIN_ENABLED=true

# Live GOP ingest stability
LOCAL_RING_BUFFER_ENABLED=false
LOCAL_RING_BUFFER_DIR=data/ring_buffer
LOCAL_RING_BUFFER_RETENTION_SECONDS=3600
LOCAL_RING_BUFFER_SEGMENT_SECONDS=1
GOP_BUILD_QUEUE_SIZE=128
